{
  "name": "leo-module-generator",
  "version": "2.0.14",
  "description": "Generate Express modules with Mongoose models",
  "main": "dist/index.js",
  "bin": {
    "leo-create": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-templates",
    "copy-templates": "if not exist dist\\templates mkdir dist\\templates && xcopy /E /I /Y src\\templates\\*.hbs dist\\templates\\",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"try { require('fs').chmodSync(require('path').join(__dirname, 'dist/index.js'), '755') } catch(e) {}\""
  },
  "keywords": [
    "leo",
    "messi",
    "express",
    "mongoose",
    "generator",
    "module",
    "cli"
  ],
  "author": "Asaduzzaman",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.9.0",
    "commander": "^11.1.0",
    "handlebars": "^4.7.8",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3"
  },
  "moduleGenerator": {
    "modulesDir": "src/app/modules",
    "routesFile": "src/routes/index.ts",
    "postman": {
      "apiKey": "YOUR_POSTMAN_API_KEY",
      "collectionId": "YOUR_COLLECTION_ID",
      "workspaceId": "YOUR_WORKSPACE_ID",
      "baseUrl": "http://localhost:5000/api/v1",
      "projectName": "TEMPLATE"
    }
  }
}
